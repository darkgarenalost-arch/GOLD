# Optional deployment URL used in generated alert links.
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Optional cron hardening. If set, external cron calls must send:
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Alert threshold defaults to 80 when omitted.
ALERT_MIN_SCORE=80

# Optional Resend email alerts.
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Optional chat/webhook alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
